# ==================================================
# Stock Mixer - Kiwoom REST API 환경변수 설정
# ==================================================
# 이 파일을 복사하여 .env 파일을 생성하고, 실제 키값을 입력하세요.
# cp .env.example .env

# --------------------------------------------------
# 모드 설정
# --------------------------------------------------
# mock  : 키움 API 없이 랜덤 가격으로 시뮬레이션 (기본값)
# real  : 실제 키움 REST API 호출 (아래 키 필요)
KIWOOM_MODE=mock

# --------------------------------------------------
# 키움증권 REST API 인증 정보
# KIWOOM_MODE=real 로 변경 후 아래 값 입력
# --------------------------------------------------
# 발급 위치: https://openapi.kiwoom.com → 앱키 발급
KIWOOM_APP_KEY=여기에_앱키_입력
KIWOOM_SECRET_KEY=여기에_시크릿키_입력

# --------------------------------------------------
# 서버 설정
# --------------------------------------------------
PORT=3000

# --------------------------------------------------
# 키움 API 서버 주소 (변경 불필요)
# --------------------------------------------------
# 실전투자: https://api.kiwoom.com
# 모의투자: https://mockapi.kiwoom.com
KIWOOM_BASE_URL=https://api.kiwoom.com
